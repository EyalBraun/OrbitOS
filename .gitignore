# =================================================================
# OrbitOS Git Exclusion List
# =================================================================

# --- 1. Build Artifacts ---
# We ignore these because they are machine-specific (Linux vs Mac vs Windows)
build/
bin/
*.o
*.out

# Specific executables generated by your Makefile
orbit_os
fs_test
main

# --- 2. Persistent Data & Disk Images ---
# We ignore the data folder so everyone starts with a fresh VFS
data/
*.bin
orbit_data.bin

# --- 3. Development Tools & Editor Junk ---
# Neovim / Vim swap files (created when you are editing)
*.swp
*.swo
*.swn
.netrwhist

# VS Code folders (if you or a collaborator use it)
.vscode/
.history/

# MacOS specific files
.DS_Store

# --- 4. Logs & Temp Files ---
*.log
tests/temp_out.txt
